# ── Neo4j / Hetionet ──────────────────────────────────────────────────────────
# Production: use your AuraDB Free instance URI + credentials
# Local dev: public read-only instance below (no writes)
NEO4J_URI=bolt://neo4j.het.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j

# ── Gemini API ────────────────────────────────────────────────────────────────
# Get key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_ADK_MODEL=gemini-2.0-flash

# ── GCP Project (required for Cloud Run deploy) ───────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ── Database (session persistence) ───────────────────────────────────────────
# Local: leave unset — SQLite is used automatically (hetionet_sessions.db)
# Cloud Run: set to Cloud SQL Postgres connection string
# DATABASE_URL=postgresql+asyncpg://user:password@/dbname?host=/cloudsql/project:region:instance

# ── MCP Toolbox (optional) ────────────────────────────────────────────────────
# Leave unset — cypher_agent uses direct neo4j_tools.py by default.
# MCP_TOOLBOX_URL=http://localhost:5000
